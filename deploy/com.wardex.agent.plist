<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wardex.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/wardex</string>
        <string>serve</string>
        <string>--port</string>
        <string>8080</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/usr/local/var/wardex</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>SENTINEL_CORS_ORIGIN</key>
        <string>http://localhost:8080</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>/usr/local/var/log/wardex.log</string>
    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/wardex.err</string>
</dict>
</plist>
